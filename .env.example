# Supabase project values used by the session record sync path.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth values for the native provider callback.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_AUTH_REDIRECT_SCHEME=luno

# Optional local QA values for exercising the guest-to-signed-in transition
# before Apple/Google OAuth credentials are connected. Preview user ids must
# be Supabase auth UUIDs, not provider-only ids.
EXPO_PUBLIC_AUTH_PREVIEW_USER_ID=00000000-0000-4000-8000-000000000000
EXPO_PUBLIC_APPLE_AUTH_PREVIEW_USER_ID=
EXPO_PUBLIC_GOOGLE_AUTH_PREVIEW_USER_ID=
EXPO_PUBLIC_AUTH_PREVIEW_EMAIL=qa@example.com
EXPO_PUBLIC_AUTH_PREVIEW_ACCESS_TOKEN=
