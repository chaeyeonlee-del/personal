{
  "name": "hoo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node --experimental-strip-types --test *.test.ts",
    "typecheck": "tsc --noEmit",
    "build:web": "expo export --platform web",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:testflight": "eas build --platform ios --profile production",
    "submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/three": "^0.184.1",
    "eas-cli": "^19.0.8",
    "typescript": "~5.9.2"
  },
  "private": true
}
